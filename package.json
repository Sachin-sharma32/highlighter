{
  "name": "marginalia",
  "private": true,
  "version": "0.1.0",
  "description": "Marginalia — a modern web highlighter (dashboard + Chrome extension)",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "convex": "convex dev",
    "dev:web": "pnpm --filter web dev",
    "dev:ext": "pnpm --filter extension dev",
    "build:web": "pnpm --filter web build",
    "build:ext": "pnpm --filter extension build",
    "build:ext:prod": "VITE_CONVEX_URL=https://blessed-finch-705.convex.cloud VITE_DASHBOARD_URL=https://highlighter-web-gdqs.vercel.app pnpm --filter ./extension build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "convex": "^1.36.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,css,html,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
