{
  "name": "marginalia",
  "private": true,
  "version": "0.1.0",
  "description": "Marginalia — a modern web highlighter (dashboard + Chrome extension)",
  "workspaces": [
    "web",
    "extension"
  ],
  "scripts": {
    "convex": "convex dev",
    "dev:web": "npm run dev -w web",
    "dev:ext": "npm run dev -w extension",
    "build:web": "npm run build -w web",
    "build:ext": "npm run build -w extension",
    "build:ext:prod": "VITE_CONVEX_URL=https://blessed-finch-705.convex.cloud VITE_DASHBOARD_URL=https://highlighter-web-gdqs.vercel.app npm run build -w extension",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "convex": "^1.36.1"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91"
  }
}
