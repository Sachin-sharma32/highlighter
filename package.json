{
  "name": "marginalia",
  "private": true,
  "version": "0.1.0",
  "description": "Marginalia — a modern web highlighter (dashboard + Chrome extension)",
  "workspaces": [
    "web",
    "extension"
  ],
  "scripts": {
    "convex": "convex dev",
    "dev:web": "npm run dev -w web",
    "dev:ext": "npm run dev -w extension",
    "build:web": "npm run build -w web",
    "build:ext": "npm run build -w extension",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "convex": "^1.17.0"
  }
}
