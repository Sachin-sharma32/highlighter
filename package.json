{
  "name": "marginalia",
  "private": true,
  "version": "0.1.0",
  "description": "Marginalia — a modern web highlighter (dashboard + Chrome extension)",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "convex": "convex dev",
    "dev:web": "pnpm --filter web dev",
    "dev:ext": "pnpm --filter extension dev",
    "build:web": "pnpm --filter web build",
    "build:ext": "pnpm --filter extension build",
    "build:ext:prod": "VITE_CONVEX_URL=https://blessed-finch-705.convex.cloud VITE_DASHBOARD_URL=https://highlighter-web-gdqs.vercel.app pnpm --filter ./extension build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "convex": "^1.36.1"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
