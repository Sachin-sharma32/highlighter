# Convex
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# Convex Auth — Google provider
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public URL the dashboard is served at (used for OAuth callback + extension externally_connectable)
SITE_URL=http://localhost:5173

# Enable local credentials sign-in (playwright provider) for development
AUTH_ENABLE_PLAYWRIGHT=1

# Chrome extension ID (filled in after first `npm run build -w extension` + loading unpacked)
VITE_EXTENSION_ID=
