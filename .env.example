# Convex
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
VITE_DASHBOARD_URL=http://localhost:5173

# Convex Auth — Google provider
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Convex provides CONVEX_SITE_URL automatically for HTTP Actions.
# Do not set it manually.
# Optional: only if you configure a custom domain for Convex HTTP Actions,
# set CUSTOM_AUTH_SITE_URL in Convex dashboard/CLI to that Convex custom domain.
# CUSTOM_AUTH_SITE_URL=

# Enable local credentials sign-in (playwright provider) for development
AUTH_ENABLE_PLAYWRIGHT=1

# Chrome extension ID (filled in after first `npm run build -w extension` + loading unpacked)
VITE_EXTENSION_ID=
